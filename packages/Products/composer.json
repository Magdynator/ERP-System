{
    "name": "erp/products",
    "description": "ERP Products - Products and Categories",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Erp\\Products\\": "src/",
            "Erp\\Products\\Database\\": "Database/"
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "erp/core": "@dev"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Erp\\Products\\Providers\\ProductsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
