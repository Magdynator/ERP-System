{
    "name": "erp/sales",
    "description": "ERP Sales - Sales, Sale Items, Payments",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Erp\\Sales\\": "src/"
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "erp/core": "@dev",
        "erp/products": "@dev",
        "erp/inventory": "@dev",
        "erp/accounting": "@dev"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Erp\\Sales\\Providers\\SalesServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
