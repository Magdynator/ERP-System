{
    "name": "erp/accounting",
    "description": "ERP Accounting - Double-entry accounting",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Erp\\Accounting\\": "src/",
            "Erp\\Accounting\\Database\\": "Database/"
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "erp/core": "@dev"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Erp\\Accounting\\Providers\\AccountingServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
