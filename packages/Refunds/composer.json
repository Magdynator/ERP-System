{
    "name": "erp/refunds",
    "description": "ERP Refunds - Refunds with reverse accounting and stock return",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Erp\\Refunds\\": "src/"
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "erp/core": "@dev",
        "erp/products": "@dev",
        "erp/inventory": "@dev",
        "erp/accounting": "@dev",
        "erp/sales": "@dev"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Erp\\Refunds\\Providers\\RefundsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
